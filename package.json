{
  "name": "podnet",
  "version": "1.0.0",
  "description": "PodNet — Neighborhood Gig & Improvement Board (Cloudflare-native)",
  "private": true,
  "license": "Unlicense",
  "type": "module",
  "scripts": {
    "setup": "node scripts/setup.mjs",
    "dev": "wrangler pages dev",
    "db:init": "wrangler d1 execute podnet --remote --file schema.sql",
    "db:init:local": "wrangler d1 execute podnet --local --file schema.sql",
    "db:backup": "wrangler d1 export podnet --remote --output podnet-backup.sql",
    "icons": "node scripts/make-icons.mjs",
    "deploy": "wrangler pages deploy",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "format": "biome format --write .",
    "test": "vitest run"
  },
  "dependencies": {
    "hono": "^4.6.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@cloudflare/vitest-pool-workers": "^0.16.14",
    "@cloudflare/workers-types": "^4.20260610.1",
    "typescript": "^5.6.0",
    "vitest": "^4.1.8",
    "wrangler": "^4.99.0"
  }
}
